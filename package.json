{
  "name": "logfish",
  "displayName": "LogFish",
  "description": "Stream and filter large log files with line-based highlighting.",
  "version": "1.0.0",
  "publisher": "rprueller",
  "repository": "https://github.com/rprueller/logfish",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "out/**/*.js",
    "media/**",
    "README.md",
    "LICENSE.md"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "logFish.openLog",
        "title": "LogFish: Open File"
      },
      {
        "command": "logFish.openInViewer",
        "title": "Open in LogFish"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "logFish.openInViewer",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "logFish.openInViewer",
          "when": "resourceScheme == file || resourceScheme == vscode-remote",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "logFish.viewer",
        "displayName": "LogFish",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ]
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.log": "logFish.viewer"
      }
    },
    "configuration": {
      "title": "LogFish",
      "properties": {
        "logFish.highlightRules": {
          "type": "array",
          "default": [
            {
              "name": "Default",
              "filePattern": ".*\\.log",
              "rules": [
                {
                  "pattern": "critical",
                  "patternIgnoreCase": true,
                  "color": "#ffffff",
                  "background": "#c62828",
                  "fontWeight": "bold"
                },
                {
                  "pattern": "error",
                  "patternIgnoreCase": true,
                  "color": "#cc0000",
                  "fontWeight": "bold"
                },
                {
                  "pattern": "warn(ing)?",
                  "patternIgnoreCase": true,
                  "color": "#e87d02"
                },
                {
                  "pattern": "debug",
                  "patternIgnoreCase": true,
                  "color": "#808080"
                }
              ]
            }
          ],
          "scope": "resource",
          "description": "Per-line highlighting rules or rule groups. Global rules will always be used, whereas only the first matching file pattern will be effective. Rule: { pattern, patternIgnoreCase?, color?, background?, fontStyle?, fontWeight? }. Group: { name?, filePattern, filePatternIgnoreCase?, rules: [...] } — name sets the profile label shown in the UI (defaults to filePattern)."
        },
        "logFish.maxCachedLines": {
          "type": "number",
          "default": 20000,
          "minimum": 500,
          "scope": "resource",
          "description": "Maximum number of matched lines cached in the UI while scrolling."
        },
        "logFish.filterDelayMs": {
          "type": "number",
          "default": -1,
          "scope": "resource",
          "description": "Delay in ms before a changed filter input triggers a re-reading of the file. Use a negative value to disable auto-filtering — the filter is only applied when Enter is pressed."
        },
        "logFish.filterPersistence": {
          "type": "string",
          "enum": [
            "workspace",
            "global",
            "workspaceThenGlobal"
          ],
          "default": "workspaceThenGlobal",
          "scope": "resource",
          "description": "Where to remember the last filter. workspace: per-workspace only. global: across all workspaces only. workspaceThenGlobal: prefer workspace value and also write global."
        }
      }
    }
  },

  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
